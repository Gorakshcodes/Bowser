PORT=3000

# Zoom Server-to-Server OAuth configuration
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Zoom user email or user id used to create meetings
ZOOM_USER_ID=teacher@yourdomain.com

# Microsoft Teams meetings currently use manual join links in the app,
# so no Teams API credentials are required for basic scheduling.
